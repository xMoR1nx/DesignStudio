# Використовуємо офіційний образ Node.js
FROM node:18-alpine

# Створюємо робочу папку всередині контейнера
WORKDIR /app

# Копіюємо файли з залежностями
COPY package*.json ./

# Встановлюємо всі бібліотеки
RUN npm install

# Копіюємо весь інший код проєкту
COPY . .

# Відкриваємо порт 3000
EXPOSE 3000

# Команда для запуску сервера
CMD ["node", "server-all.js"]